[
  {
    "id": "items",
    "name": "items",
    "label": "Prototipos",
    "type": "group",
    "repeater": true,
    "occurrence": { "min": 1, "max": 8, "default": 4 },
    "children": [
      {
        "id": "prototipo_imagen",
        "name": "prototipo_imagen",
        "label": "Imagen",
        "type": "image",
        "default": { "src": "", "alt": "", "loading": "lazy" }
      },
      {
        "id": "prototipo_nombre",
        "name": "prototipo_nombre",
        "label": "Nombre del prototipo",
        "type": "text",
        "default": "Prototipo"
      },
      {
        "id": "prototipo_m2",
        "name": "prototipo_m2",
        "label": "Metros cuadrados",
        "type": "richtext",
        "default": "00.00 m²"
      },
      {
        "id": "prototipo_desc",
        "name": "prototipo_desc",
        "label": "Descripción",
        "type": "text",
        "default": ""
      },
      {
        "id": "prototipo_enlace",
        "name": "prototipo_enlace",
        "label": "Enlace (página del prototipo)",
        "type": "link",
        "default": { "url": { "href": "" }, "open_in_new_tab": false }
      },
      {
        "id": "prototipo_type",
        "name": "prototipo_type",
        "label": "Tipo de construcción",
        "type": "choice",
        "display": "select",
        "choices": [
          ["depa", "Depa"],
          ["casa", "Casa"]
        ],
        "default": "depa"
      },
      {
        "id": "is_lockoff",
        "name": "is_lockoff",
        "label": "Lock-off",
        "type": "boolean",
        "display": "checkbox",
        
        "default": false
      }
    ]
  }
]
